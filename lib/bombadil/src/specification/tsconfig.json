{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    "rootDir": "./.",
    "paths": {
      "@antithesishq/bombadil": [
        "./index.ts"
      ],
      "@antithesishq/bombadil/browser": [
        "./browser/index.ts"
      ],
      "@antithesishq/bombadil/browser/defaults": [
        "./browser/defaults.ts"
      ],
      "@antithesishq/bombadil/browser/defaults/actions": [
        "./browser/defaults/actions.ts"
      ],
      "@antithesishq/bombadil/browser/defaults/properties": [
        "./browser/defaults/properties.ts"
      ],
      "@antithesishq/bombadil/browser/dom": [
        "./browser/dom.ts"
      ],
      "@antithesishq/bombadil/terminal": [
        "./terminal/index.ts"
      ],
      "@antithesishq/bombadil/terminal/defaults": [
        "./terminal/defaults.ts"
      ],
      "@antithesishq/bombadil/terminal/defaults/properties": [
        "./terminal/defaults/properties.ts"
      ],
      "@antithesishq/bombadil/terminal/defaults/actions": [
        "./terminal/defaults/actions.ts"
      ],
      "@antithesishq/bombadil/internal": [
        "./internal.ts"
      ],
      "@antithesishq/bombadil/actions": [
        "./actions.ts"
      ]
    },
    // Environment Settings
    "module": "nodenext",
    "target": "esnext",
    "types": [],
    "lib": [
      "es2021",
      "dom"
    ],
    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    // Style Options
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,
    "allowImportingTsExtensions": true,
    "emitDeclarationOnly": true,
    // Recommended Options
    "strict": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "exclude": [
    "**/node_modules"
  ]
}
